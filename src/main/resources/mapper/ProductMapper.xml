<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.guat.lzp.product.mapper.ProductMapper">

    <resultMap id="ProductVOResultMap" type="com.guat.lzp.product.entity.ProductVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="photoUrl" column="photo_url"/>
        <result property="price" column="price"/>
        <result property="descp" column="descp"/>
        <result property="releaseDate" column="release_date"/>
        <result property="catId" column="cat_id"/>
        <result property="categoryName" column="category_name"/>
    </resultMap>

    <select id="findByPage" resultMap="ProductVOResultMap">
        SELECT p.*, c.name as category_name
        FROM product p
        LEFT JOIN category c ON p.cat_id = c.id
        <where>
            <if test="name != null and name != ''">
                AND p.name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="catId != null">
                AND p.cat_id = #{catId}
            </if>
        </where>
        ORDER BY p.id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByCondition" resultType="int">
        SELECT COUNT(*)
        FROM product p
        <where>
            <if test="name != null and name != ''">
                AND p.name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="catId != null">
                AND p.cat_id = #{catId}
            </if>
        </where>
    </select>

    <select id="findById" resultMap="ProductVOResultMap">
        SELECT p.*, c.name as category_name
        FROM product p
        LEFT JOIN category c ON p.cat_id = c.id
        WHERE p.id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (name, photo_url, price, descp, release_date, cat_id)
        VALUES (#{name}, #{photoUrl}, #{price}, #{descp}, #{releaseDate}, #{catId})
    </insert>

    <update id="update">
        UPDATE product
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="photoUrl != null">photo_url = #{photoUrl},</if>
            <if test="price != null">price = #{price},</if>
            <if test="descp != null">descp = #{descp},</if>
            <if test="releaseDate != null">release_date = #{releaseDate},</if>
            <if test="catId != null">cat_id = #{catId},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM product WHERE id = #{id}
    </delete>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM product
    </select>

</mapper>
